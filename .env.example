# Clerk (Dashboard → API Keys → Publishable key). Required for login/register UI.
VITE_CLERK_PUBLISHABLE_KEY=

# Set on Vercel (and locally if needed) at build time — Vite bakes this into the bundle.
# Must be the full URL of your Express API (the same server that serves /uploads).
# Example: https://your-api.onrender.com
# If unset in production builds, the client defaults to https://server-reseller.onrender.com
VITE_API_URL=
